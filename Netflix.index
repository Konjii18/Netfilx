<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Netflix</title>
  <link rel="stylesheet" href="style.css">
</head>
<body>
  <div class="hero-bg">
    <header>
      <img src="https://th.bing.com/th/id/R.033c9f5edecaa49d48e351389b5711c5?rik=XGsgw9KCXp%2fvXg&pid=ImgRaw&r=0" 
           width="130" alt="Netflix Logo">
           
      <a href="signin.html" class="btn">Sign In</a>
    </header>
<div class="language-selector">
  <label for="language"></label>
  <select id="language" onchange="changeLanguage()">
    <option value="en">English</option>
    <option value="hi">हिन्दी (Hindi)</option>
    <option value="ne">नेपाली (Nepali)</option>
    <option value="es">Español (Spanish)</option>
    <option value="fr">Français (French)</option>
  </select>
</div>


    <main class="container">
      <section class="hero">
        <h1>Unlimited movies,<br>TV shows, and more</h1>
        <p>Starts at USD 2.99. Cancel anytime.</p>
        <p>Ready to watch? Enter your email to create or restart your membership.</p>
        <form action="/submit_form" method="post">
          <label for="email">Email</label><br>
          <input type="email" placeholder="Enter your email here" id="email" name="email" required>
          <button type="submit" class="btn">Get Started</button>
        </form>
    </main>
  </div>
  <hr>

  </section>


  <section class="trending">
    <h2>Trending Now</h2>
    <!-- Thumbnails -->
    <img src="https://img-cdn.publive.online/fit-in/1280x720/filters:format(webp)/industry-wired/media/media_files/2026/03/09/dhurandhar-2-trailer-breakdown-2026-03-09-22-28-08.jpg"  
         alt="Dhurandhar 2 Poster" width="250" height="250" onclick="showPopup()"> 
    <img src="https://thf.bing.com/th/id/OIP.JxMCX6fz1csBXlvSeHYd7gHaKk?w=126&h=180&c=7&r=0&o=7&cb=thfc1falcon&dpr=1.3&pid=1.7&rm=3" 
         alt="Kapil Shamra Poster" width="250" height="250" onclick="showPopup()">
    <img src="https://images.timesnownews.com/thumb/msid-154342409,updatedat-1779182344000,thumbsize-54036,width-1280,height-720,resizemode-75/154342409.jpg" 
         alt="Poster" width="250" height="250" onclick="showPopup()">
    <img src="https://tse4.mm.bing.net/th/id/OIP.gF-bvz9CWOQbbin4Gjy22gHaJQ?cb=thfc1falcon&rs=1&pid=ImgDetMain&o=7&rm=3" 
         alt="Poster" width="250" height="250" onclick="showPopup()">

    <!-- Popup -->
    <div id="popup" onclick="hidePopup()">
      <img src="C:\Users\Acer\OneDrive\Desktop\Netflix\Screenshot 2026-05-25 164629.png" height="300" alt="Full Poster">
      <img src="C:\Users\Acer\OneDrive\Desktop\Netflix\Screenshot 2026-05-25 165104.png" height="300" alt="Full Poster">
      <img src="C:\Users\Acer\OneDrive\Desktop\Netflix\Screenshot 2026-05-25 234842.png" height="300" alt="Full Poster">
      <img src="C:\Users\Acer\OneDrive\Desktop\Netflix\Screenshot 2026-05-25 235826.png" height="300" alt="Full Poster">
    </div>

    <script>
      function showPopup() {
        document.getElementById("popup").style.display = "block";
      }
      function hidePopup() {
        document.getElementById("popup").style.display = "none";
      }
    </script>

    <div class="reasons-section">
      <h3>More Reasons to Join</h3>
      <div class="reasons-grid">
        <div class="reason-card">
          <div class="reason-icon">📺</div>
          <h3>Enjoy on your TV</h3>
          <p>Watch on Smart TVs, Playstation, Xbox, Chromecast, Apple TV, Blu-ray players, and more.</p>
        </div>
        <div class="reason-card">
          <div class="reason-icon">⬇️</div>
          <h3>Download your shows</h3>
          <p>Save your favorites easily and watch offline anytime.</p>
        </div>
        <div class="reason-card">
          <div class="reason-icon">✨</div>
          <h3>Watch everywhere</h3>
          <p>Stream unlimited movies and TV shows on phones, tablets, laptops, and TVs.</p>
        </div>
        <div class="reason-card">
          <div class="reason-icon">👩‍👩‍👧‍👦</div>
          <h3>Create profiles for kids</h3>
          <p>Send kids on adventures with their favorite characters in a space made just for them.</p>
        </div>
      </div>
    </div>
  </section>
</body>
<footer class="end">

<I>Netflix Nepal<br>

This page is protected by Google reCAPTCHA to ensure you're not a bot.</I>
</footer>
</html>
